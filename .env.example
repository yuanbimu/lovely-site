# Bilibili Cookie 配置
# 从浏览器开发者工具获取 https://space.bilibili.com 的 Cookie

# B 站用户 ID（默认：3821157）
BILIBILI_UID=3821157

# 以下 Cookie 值需要从浏览器复制
# 获取方法：
# 1. 打开浏览器开发者工具（F12）
# 2. 访问 https://space.bilibili.com/3821157
# 3. 切换到 Network 标签，刷新页面
# 4. 找到任意 API 请求
# 5. 复制 Request Headers 中的 Cookie 值
# 6. 提取对应的值

BILI_JCT=your_bili_jct_here
BUVID3=your_buvid3_here
BUVID4=your_buvid4_here
BILIBILI_SESSDATA=your_sessdata_here

# Cloudflare 配置（用于生产环境部署）
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_API_TOKEN=your_api_token_here
