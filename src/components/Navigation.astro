---
const navItems = [
  { label: '首页', href: '/' },
  { label: '关于', href: '/about' },
  { label: '文章', href: '/articles' },
  { label: '动态', href: '/dynamics' },
  { label: '橱窗', href: '/showcase' },
  { label: '链接', href: '/links' },
];
---

<header class="glass-nav">
  <nav class="nav-content">
    {navItems.slice(0, 3).map(item => (
      <a href={item.href} class="nav-link desktop-only">{item.label}</a>
    ))}

    <a href="/" class="logo-wrapper">
      <img src="/images/Logo.jpg" alt="Lovely Logo" class="logo-img" width="120" height="60" loading="eager" decoding="async" onerror="this.style.display='none';this.parentElement.innerHTML='<span style=\'font-size:20px;font-weight:700;color:#6B5637;\'>Lovely</span>'" />
    </a>

    {navItems.slice(3).map(item => (
      <a href={item.href} class="nav-link desktop-only">{item.label}</a>
    ))}

    <!-- 移动端汉堡菜单按钮 -->
    <button class="hamburger-btn mobile-only" aria-label="菜单" aria-expanded="false" onclick="toggleMenu()">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </nav>

  <!-- 移动端菜单 -->
  <div class="mobile-menu" id="mobileMenu">
    {navItems.map(item => (
      <a href={item.href} class="mobile-nav-link" onclick="closeMenu()">{item.label}</a>
    ))}
  </div>
</header>

<script>
  function toggleMenu() {
    const menu = document.getElementById('mobileMenu');
    const btn = document.querySelector('.hamburger-btn');
    menu?.classList.toggle('active');
    btn?.classList.toggle('active');
    btn?.setAttribute('aria-expanded', menu?.classList.contains('active') ? 'true' : 'false');
    document.body.classList.toggle('menu-open');
  }

  function closeMenu() {
    const menu = document.getElementById('mobileMenu');
    const btn = document.querySelector('.hamburger-btn');
    menu?.classList.remove('active');
    btn?.classList.remove('active');
    btn?.setAttribute('aria-expanded', 'false');
    document.body.classList.remove('menu-open');
  }
</script>

<style>
  .glass-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(196, 167, 71, 0.2);
  }

  .nav-content {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    height: 70px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 30px;
    flex-wrap: wrap;
  }

  .nav-link {
    padding: 10px 18px;
    color: #6B5637;
    text-decoration: none;
    border-radius: 25px;
    font-weight: 500;
    font-size: 14px;
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .nav-link:hover {
    background: rgba(255, 255, 255, 0.6);
    color: #4A90D9;
  }

  .logo-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 15px;
  }

  .logo-img {
    height: 60px;
    width: auto;
    border-radius: 8px;
    transition: transform 0.3s ease;
  }

  .logo-img:hover {
    transform: scale(1.05);
  }

  /* 汉堡菜单按钮 */
  .hamburger-btn {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 30px;
    height: 24px;
    padding: 0;
    background: transparent;
    border: none;
    cursor: pointer;
    z-index: var(--z-hamburger);
  }

  .hamburger-line {
    display: block;
    width: 100%;
    height: 3px;
    background: #6B5637;
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  .hamburger-btn.active .hamburger-line:nth-child(1) {
    transform: translateY(10.5px) rotate(45deg);
  }

  .hamburger-btn.active .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .hamburger-btn.active .hamburger-line:nth-child(3) {
    transform: translateY(-10.5px) rotate(-45deg);
  }

  /* 移动端菜单 */
  .mobile-menu {
    display: none;
    position: fixed;
    top: 70px;
    left: 0;
    right: 0;
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(20px);
    padding: 20px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    z-index: var(--z-hamburger);
    transform: translateY(-100%);
    opacity: 0;
    transition: all 0.3s ease;
  }

  .mobile-menu.active {
    transform: translateY(0);
    opacity: 1;
  }

  .mobile-nav-link {
    display: block;
    padding: 16px 20px;
    color: #6B5637;
    font-size: 16px;
    font-weight: 500;
    border-radius: 12px;
    margin-bottom: 8px;
    transition: all 0.3s ease;
  }

  .mobile-nav-link:hover {
    background: rgba(214, 235, 248, 0.5);
    color: #4A90D9;
  }

  /* 防止滚动 */
  body.menu-open {
    overflow: hidden;
  }

  /* 响应式 */
  @media (max-width: 900px) {
    .nav-content {
      gap: 10px;
      padding: 0 20px;
    }

    .nav-link {
      padding: 8px 12px;
      font-size: 13px;
    }

    .logo-img {
      height: 32px;
    }
  }

  @media (max-width: 600px) {
    .desktop-only {
      display: none;
    }

    .mobile-only {
      display: flex;
    }

    .nav-content {
      height: 60px;
      justify-content: space-between;
      padding: 0 20px;
    }

    .logo-wrapper {
      margin: 0;
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
    }

    .logo-img {
      height: 28px;
    }

    .hamburger-btn {
      display: flex;
    }
  }
</style>
