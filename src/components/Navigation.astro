---
const navItems = [
  { label: '首页', href: '/' },
  { label: '关于', href: '/about' },
  { label: '时间线', href: '/timeline' },
  { label: '歌单', href: '/songs' },
  // { label: '文章', href: '/articles' },  // TODO: 开发中，暂不显示
  { label: '橱窗', href: '/showcase' },
  { label: '链接', href: '/links' },
];
---

<header class="glass-nav">
  <nav class="nav-content">
    <!-- Logo置左 -->
    <a href="/" class="logo-wrapper">
      <img src="/images/Logo.jpg" alt="Lovely Logo" class="logo-img" width="120" height="60" loading="eager" decoding="async" onerror="this.style.display='none';this.parentElement.innerHTML='<span style=\'font-size:20px;font-weight:700;color:#6B5637;\'>Lovely</span>'" />
    </a>

    <!-- 桌面端导航链接 -->
    <div class="nav-links desktop-only">
      {navItems.map(item => (
        <a href={item.href} class="nav-link">{item.label}</a>
      ))}
    </div>

    <!-- 移动端汉堡菜单按钮 -->
    <button class="hamburger-btn mobile-only" aria-label="菜单" aria-expanded="false" id="hamburgerBtn">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </nav>

  <!-- 移动端菜单 -->
  <div class="mobile-menu" id="mobileMenu">
    {navItems.map(item => (
      <a href={item.href} class="mobile-nav-link">{item.label}</a>
    ))}
  </div>
</header>

<script is:inline>
  (function() {
    const btn = document.getElementById('hamburgerBtn');
    const menu = document.getElementById('mobileMenu');
    const nav = document.querySelector('.glass-nav');
    
    if (!btn || !menu) return;
    
    // === 当前页面高亮 ===
    function initActiveLink() {
      const path = window.location.pathname;
      const normalizedPath = path.endsWith('/') && path.length > 1 ? path.slice(0, -1) : path;
      
      // 桌面端链接
      document.querySelectorAll('.nav-link').forEach(function(link) {
        const href = link.getAttribute('href');
        const normalizedHref = href.endsWith('/') && href.length > 1 ? href.slice(0, -1) : href;
        if (normalizedHref === normalizedPath || (href === '/' && path === '/')) {
          link.classList.add('active');
        }
      });
      
      // 移动端链接
      document.querySelectorAll('.mobile-nav-link').forEach(function(link) {
        const href = link.getAttribute('href');
        const normalizedHref = href.endsWith('/') && href.length > 1 ? href.slice(0, -1) : href;
        if (normalizedHref === normalizedPath || (href === '/' && path === '/')) {
          link.classList.add('active');
        }
      });
    }
    
    // === 滚动监听 ===
    function initScrollEffect() {
      let lastScroll = 0;
      const scrollThreshold = 20;
      
      function handleScroll() {
        const currentScroll = window.scrollY;
        
        if (currentScroll > scrollThreshold) {
          nav.classList.add('scrolled');
        } else {
          nav.classList.remove('scrolled');
        }
        
        lastScroll = currentScroll;
      }
      
      // 初始检查
      handleScroll();
      
      // 使用 passive listener 优化性能
      window.addEventListener('scroll', handleScroll, { passive: true });
    }
    
    function toggleMenu() {
      menu.classList.toggle('active');
      btn.classList.toggle('active');
      btn.setAttribute('aria-expanded', menu.classList.contains('active') ? 'true' : 'false');
      document.body.classList.toggle('menu-open');
    }
    
    function closeMenu() {
      menu.classList.remove('active');
      btn.classList.remove('active');
      btn.setAttribute('aria-expanded', 'false');
      document.body.classList.remove('menu-open');
    }
    
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      toggleMenu();
    });
    
    // 点击菜单项关闭菜单
    menu.querySelectorAll('.mobile-nav-link').forEach(function(link) {
      link.addEventListener('click', closeMenu);
    });
    
    // 点击外部关闭菜单
    document.addEventListener('click', function(e) {
      if (!btn.contains(e.target) && !menu.contains(e.target) && menu.classList.contains('active')) {
        closeMenu();
      }
    });
    
    // 初始化
    initActiveLink();
    initScrollEffect();
  })();
</script>

<style>
  .glass-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-sticky);
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(196, 167, 71, 0.2);
    transition: background var(--duration-normal) ease, box-shadow var(--duration-normal) ease;
  }

  /* 滚动后状态 */
  .glass-nav.scrolled {
    background: rgba(255, 255, 255, 0.95);
    box-shadow: var(--shadow-md);
    border-bottom-color: rgba(196, 167, 71, 0.3);
  }

  .nav-content {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 30px;
    height: 70px;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .logo-wrapper {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .logo-img {
    height: 50px;
    width: auto;
    border-radius: var(--radius-sm);
    transition: transform var(--duration-normal) ease;
  }

  .logo-img:hover {
    transform: scale(1.05);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    flex: 1;
    justify-content: flex-end;
  }

  .nav-link {
    position: relative;
    padding: 8px 16px;
    color: var(--brown-600);
    text-decoration: none;
    border-radius: var(--radius-full);
    font-weight: 500;
    font-size: 14px;
    transition: color var(--duration-fast) ease, background var(--duration-fast) ease;
    white-space: nowrap;
  }

  /* 下划线效果 */
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 50%;
    width: 0;
    height: 2px;
    background: var(--blue-500);
    border-radius: var(--radius-full);
    transition: width var(--duration-fast) ease, left var(--duration-fast) ease;
  }

  .nav-link:hover {
    color: var(--blue-500);
  }

  .nav-link:hover::after {
    width: 60%;
    left: 20%;
  }

  /* 当前页面高亮 */
  .nav-link.active {
    background: rgba(74, 144, 217, 0.15);
    color: var(--blue-600);
    font-weight: 600;
  }

  .nav-link.active::after {
    width: 60%;
    left: 20%;
  }

  .nav-link.active:hover {
    background: rgba(74, 144, 217, 0.2);
  }

  /* 汉堡菜单按钮 */
  .hamburger-btn {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 28px;
    height: 22px;
    padding: 0;
    background: transparent;
    border: none;
    cursor: pointer;
    z-index: var(--z-hamburger);
  }

  .hamburger-line {
    display: block;
    width: 100%;
    height: 3px;
    background: var(--brown-600);
    border-radius: 2px;
    transition: all var(--duration-normal) ease;
  }

  .hamburger-btn.active .hamburger-line:nth-child(1) {
    transform: translateY(9.5px) rotate(45deg);
  }

  .hamburger-btn.active .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .hamburger-btn.active .hamburger-line:nth-child(3) {
    transform: translateY(-9.5px) rotate(-45deg);
  }

  /* 移动端菜单 - 使用 transform 动画替代 display 切换 */
  .mobile-menu {
    position: fixed;
    top: 70px;
    left: 0;
    right: 0;
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(20px);
    padding: 20px;
    box-shadow: var(--shadow-lg);
    z-index: 1499;
    transform: translateY(-20px);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: transform var(--duration-normal) ease, opacity var(--duration-normal) ease, visibility var(--duration-normal) ease;
  }

  .mobile-menu.active {
    transform: translateY(0);
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .mobile-nav-link {
    display: block;
    padding: 14px 20px;
    color: var(--brown-600);
    font-size: 16px;
    font-weight: 500;
    border-radius: var(--radius-md);
    margin-bottom: 6px;
    transition: all var(--duration-fast) ease;
    text-decoration: none;
  }

  .mobile-nav-link:hover {
    background: rgba(214, 235, 248, 0.5);
    color: var(--blue-500);
    transform: translateX(4px);
  }

  /* 移动端当前页面高亮 */
  .mobile-nav-link.active {
    background: rgba(74, 144, 217, 0.15);
    color: var(--blue-600);
    font-weight: 600;
  }

  /* 防止滚动 */
  body.menu-open {
    overflow: hidden;
  }

  /* 响应式 */
  @media (max-width: 1100px) {
    .nav-content {
      gap: 20px;
      padding: 0 30px;
    }

    .nav-link {
      padding: 8px 14px;
      font-size: 13px;
    }
  }

  @media (max-width: 900px) {
    .nav-content {
      padding: 0 20px;
    }

    .nav-link {
      padding: 6px 12px;
      font-size: 12px;
    }

    .logo-img {
      height: 42px;
    }
  }

  @media (max-width: 768px) {
    .desktop-only {
      display: none !important;
    }

    .mobile-only {
      display: flex !important;
    }

    .nav-content {
      height: 60px;
      justify-content: space-between;
      padding: 0 20px;
    }

    .logo-img {
      height: 40px;
    }

    .hamburger-btn {
      display: flex;
    }
  }
</style>
