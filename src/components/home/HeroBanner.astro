---
import siteData from '../../data/site-data.json';
import Avatar from '../Avatar';
import LiveStatus from '../LiveStatus';

const { profile, config } = siteData;
---

<section id="hero" class="hero-section">
  <div class="bg-orb orb-1"></div>
  <div class="bg-orb orb-2"></div>
  <div class="bg-orb orb-3"></div>

  <div class="hero-content">
    <div class="hero-left">
      <Avatar client:load size={280} />

      {config.showLiveStatus && (
        <div class="live-status-wrapper">
          <LiveStatus client:load />
        </div>
      )}
    </div>

    <div class="hero-right">
      <h1 class="site-title">{profile.name}</h1>
      <div class="fans-counter" id="fans-counter">
        <span class="fans-label">与</span>
        <span class="fans-number" id="fans-number">--</span>
        <span class="fans-label">只秧歌星相遇</span>
      </div>
      <p class="subtitle">{profile.bio}</p>

      <div class="social-buttons">
        <a href={profile.socials.bilibili} target="_blank" rel="noopener noreferrer" class="social-btn bilibili-btn">
          <svg viewBox="0 0 512 512" width="20" height="20" fill="currentColor" aria-hidden="true">
            <path d="M488.6 104.1c16.7 18.1 24.4 39.7 23.3 65.7v202.4c-.4 26.4-9.2 48.1-26.5 65.1c-17.2 17-39.1 25.9-65.5 26.7H92.02c-26.45-.8-48.21-9.8-65.28-27.2C9.682 419.4.767 396.5 0 368.2V169.8c.767-26 9.682-47.6 26.74-65.7C43.81 87.75 65.57 78.77 92.02 78h29.38L96.05 52.19c-5.75-5.73-8.63-13-8.63-21.79c0-8.8 2.88-16.06 8.63-21.797C101.8 2.868 109.1 0 117.9 0s16.1 2.868 21.9 8.603L213.1 78h88l74.5-69.397C381.7 2.868 389.2 0 398 0c8.8 0 16.1 2.868 21.9 8.603c5.7 5.737 8.6 12.997 8.6 21.797c0 8.79-2.9 16.06-8.6 21.79L394.6 78h29.3c26.4.77 48 9.75 64.7 26.1z"/>
          </svg>
          <span>B 站主页</span>
        </a>
        {profile.socials.weibo && (
          <a href={profile.socials.weibo} target="_blank" rel="noopener noreferrer" class="social-btn weibo-btn">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
               <path d="M10.098 20.323c-3.977.391-7.414-1.406-7.672-4.02-.259-2.609 2.759-5.047 6.74-5.441 3.979-.394 7.413 1.404 7.671 4.018.259 2.6-2.759 5.049-6.739 5.443zM9.05 17.219c-.384.616-1.208.884-1.829.602-.612-.279-.793-.991-.406-1.593.379-.595 1.176-.861 1.793-.601.622.263.82.972.442 1.592zm1.27-1.627c-.141.237-.449.353-.689.253-.236-.09-.313-.361-.177-.586.138-.227.436-.346.672-.24.239.09.315.36.18.573h.014zm.176-2.719c-1.893-.493-4.033.45-4.857 2.118-.836 1.704-.026 3.591 1.886 4.21 1.983.64 4.318-.341 5.132-2.179.8-1.793-.201-3.642-2.161-4.149zm7.563-1.224c-.346-.105-.577-.18-.399-.646.388-1.012.428-1.884.003-2.509-.793-1.164-2.96-1.101-5.448-.033 0 0-.781.343-.581-.277.383-1.217.324-2.236-.27-2.82-1.349-1.33-4.937.047-8.013 3.073-2.299 2.262-3.637 4.66-3.637 6.729 0 3.958 5.063 6.367 10.017 6.367 6.487 0 10.807-3.771 10.807-6.766 0-1.808-1.524-2.833-2.479-3.118zm2.809-5.582c-.939-1.061-2.326-1.465-3.586-1.273-.359.053-.609.386-.556.744.054.357.387.604.744.556.842-.124 1.712.158 2.298.82.586.662.76 1.564.516 2.374-.1.348.1.712.448.812.35.1.714-.1.814-.448.349-1.138.087-2.441-.678-3.585zm-1.113 3.286c-.393-.443-.974-.767-1.54-.637-.224.052-.361.278-.31.502.053.224.279.36.503.31.303-.071.639.083.87.343.231.261.311.618.232.925-.058.226.079.456.305.514.226.058.456-.078.514-.304.141-.541.016-1.146-.35-1.56l-.224-.093z"/>
            </svg>
            <span>微博</span>
          </a>
        )}
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function() {
    const el = document.getElementById('fans-number');
    if (!el) return;
    fetch('/api/live')
      .then(r => r.json())
      .then(data => {
        if (data && data.fans > 0) {
          el.textContent = data.fans.toLocaleString('zh-CN');
        } else {
          el.textContent = '--';
        }
      })
      .catch(() => { el.textContent = '--'; });
  })();
</script>

<style>
  .hero-section {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    background: linear-gradient(180deg, #FFF8F0 0%, #F5EDE3 30%, #E8F4FC 100%);
  }

  .bg-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    pointer-events: none;
  }

  .orb-1 {
    width: 500px;
    height: 500px;
    background: linear-gradient(135deg, #E8D4C0 0%, #D4B896 100%);
    top: -150px;
    left: -150px;
    opacity: 0.6;
  }

  .orb-2 {
    width: 600px;
    height: 600px;
    background: linear-gradient(135deg, #D6EBF8 0%, #B3D9F2 100%);
    bottom: -250px;
    right: -250px;
    opacity: 0.35;
  }

  .orb-3 {
    width: 300px;
    height: 300px;
    background: linear-gradient(135deg, #9d84b7 0%, #6a4c93 100%);
    top: 50%;
    right: 10%;
    opacity: 0.2;
  }

  /* 移动端背景球体调整 */
  @media (max-width: 600px) {
    .orb-1 {
      width: 200px;
      height: 200px;
      top: -60px;
      left: -100px;
      opacity: 0.4;
    }

    .orb-2 {
      width: 250px;
      height: 250px;
      bottom: -80px;
      right: -120px;
      opacity: 0.35;
    }

    .orb-3 {
      width: 120px;
      height: 120px;
      top: 40%;
      right: -20px;
      opacity: 0.15;
    }
  }

  .hero-content {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 100px;
    width: 100%;
    max-width: 1100px;
    padding: 60px 30px;
    margin: 0 auto;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 30px;
  }

  .avatar-wrapper {
    position: relative;
  }

  .avatar-glow {
    position: absolute;
    inset: -25px;
    background: linear-gradient(135deg, rgba(196, 167, 125, 0.5) 0%, rgba(122, 184, 232, 0.5) 100%);
    border-radius: 50%;
    filter: blur(35px);
    z-index: -1;
  }

  .avatar {
    width: 280px;
    height: 280px;
    object-fit: cover;
    border-radius: 50%;
    border: 8px solid white;
    box-shadow: 0 20px 60px rgba(139, 111, 71, 0.25);
  }

  .live-status-wrapper {
    margin-top: 15px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .hero-right {
    text-align: left;
  }

  .site-title {
    font-size: clamp(2rem, 5vw, 56px);
    font-weight: 700;
    color: #6B5637;
    margin: 0 0 10px 0;
    letter-spacing: 3px;
    line-height: 1.2;
  }

  .fans-counter {
    display: block;
    margin: 0 0 16px 0;
    font-size: clamp(1rem, 2vw, 18px);
    color: #8B6F47;
    letter-spacing: 0.5px;
    line-height: 1.6;
  }

  .fans-counter .fans-number {
    font-size: 1.1em;
    font-weight: 700;
    color: #6B5637;
  }

  .subtitle {
    font-size: clamp(1rem, 3vw, 20px);
    color: #8B6F47;
    margin: 0 0 35px 0;
    letter-spacing: 1px;
  }

  .social-buttons {
    display: flex;
    gap: 15px;
  }

  .social-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 28px;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 600;
    font-size: 15px;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .social-btn:focus {
    outline: 3px solid #4A90D9;
    outline-offset: 3px;
  }

  .bilibili-btn {
    background: linear-gradient(135deg, #00aeec 0%, #0090d4 100%);
    color: white;
  }

  .weibo-btn {
    background: linear-gradient(135deg, #E6162D 0%, #c01224 100%);
    color: white;
  }

  .social-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
  }

  @media (max-width: 1000px) {
    .hero-content {
      flex-direction: column;
      text-align: center;
      gap: 50px;
      padding: 100px 25px 60px;
    }

    .hero-right {
      text-align: center;
    }

    .social-buttons {
      justify-content: center;
    }
  }

  @media (max-width: 600px) {
    .avatar {
      width: 200px;
      height: 200px;
      border-width: 6px;
    }

    .site-title {
      font-size: 32px;
      letter-spacing: 2px;
    }

    .fans-counter {
      font-size: 16px;
      margin: 0 0 14px 0;
    }

    .subtitle {
      font-size: 15px;
      margin: 0 0 25px 0;
    }

    .social-buttons {
      flex-direction: column;
      align-items: center;
      gap: 12px;
    }

    .social-btn {
      width: 100%;
      max-width: 280px;
      justify-content: center;
      padding: 14px 24px;
      font-size: 14px;
    }

    .hero-content {
      padding: 80px 20px 40px;
      gap: 40px;
    }
  }

  /* 超小屏幕优化 (320px-375px) */
  @media (max-width: 375px) {
    .avatar {
      width: 180px;
      height: 180px;
    }

    .site-title {
      font-size: 28px;
    }

    .fans-counter {
      font-size: 15px;
    }

    .subtitle {
      font-size: 14px;
    }

    .social-btn {
      padding: 12px 20px;
      font-size: 13px;
    }

    .orb-1 {
      width: 200px;
      height: 200px;
    }

    .orb-2 {
      width: 250px;
      height: 250px;
    }
  }
</style>
