---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import TimelineList from '../components/TimelineList';
---

<Layout title="时间线 - 东爱璃 Lovely">
  <Navigation />
  
  <main class="timeline-page">
    <!-- Hero Section -->
    <section class="hero-section">
      <div class="container">
        <h1 class="page-title">时间线</h1>
        <p class="page-subtitle">记录东爱璃Lovely的成长历程</p>
      </div>
    </section>

    <!-- Timeline Section -->
    <section class="timeline-section">
      <div class="container">
        <TimelineList client:load />
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>

<style>
  .timeline-page {
    min-height: 100vh;
    background: linear-gradient(135deg, #FAF6F0 0%, #F5EDE3 100%);
  }

  .hero-section {
    padding: 140px 20px 60px;
    text-align: center;
    background: linear-gradient(135deg, rgba(107, 86, 55, 0.05) 0%, rgba(74, 144, 217, 0.05) 100%);
  }

  .page-title {
    font-size: 2.5rem;
    color: #6B5637;
    margin-bottom: 12px;
    font-weight: 700;
  }

  .page-subtitle {
    font-size: 1.1rem;
    color: #8B7355;
    max-width: 500px;
    margin: 0 auto;
  }

  .timeline-section {
    padding: 60px 20px 100px;
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
  }

  @media (max-width: 480px) {
    .hero-section {
      padding: 120px 16px 40px;
    }

    .timeline-section {
      padding: 40px 16px 60px;
    }
    
    .page-title {
      font-size: 2rem;
    }
  }
</style>
