---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import SongsList from '../components/SongsList';
---

<Layout title="歌单 - 东爱璃Lovely">
  <Navigation />
  
  <main class="songs-page">
    <!-- Hero Section -->
    <section class="hero-section">
      <div class="container">
        <h1 class="page-title">歌单</h1>
        <p class="page-subtitle">东爱璃Lovely的歌曲收藏</p>
      </div>
    </section>

    <!-- Songs List -->
    <section class="songs-section">
      <div class="container">
        <SongsList client:load />
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>

<style>
  .songs-page {
    min-height: 100vh;
    background: linear-gradient(135deg, #FAF6F0 0%, #F5EDE3 100%);
  }

  .hero-section {
    padding: 140px 20px 40px;
    text-align: center;
    background: linear-gradient(135deg, rgba(107, 86, 55, 0.05) 0%, rgba(74, 144, 217, 0.05) 100%);
  }

  .page-title {
    font-size: 2.5rem;
    color: #6B5637;
    margin-bottom: 12px;
    font-weight: 700;
  }

  .page-subtitle {
    font-size: 1.1rem;
    color: #8B7355;
  }

  .songs-section {
    padding: 40px 20px 100px;
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .page-title {
      font-size: 2rem;
    }
  }

  @media (max-width: 480px) {
    .hero-section {
      padding: 120px 16px 30px;
    }

    .songs-section {
      padding: 30px 16px 60px;
    }
  }
</style>
