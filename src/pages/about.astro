---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import ContributorsWall from '../components/ContributorsWall';
---

<Layout title="关于本站 - 东爱璃Lovely">
  <Navigation />

  <main class="about-page">
    <section class="hero-section">
      <div class="container">
        <h1 class="page-title">关于本站</h1>
        <p class="page-subtitle">一个由粉丝为粉丝打造的应援站</p>
      </div>
    </section>

    <section class="content-section">
      <div class="container">
        <div class="content-card">
          <h2>🌸 这是什么站？</h2>
          <p>
            这是<strong>东爱璃Lovely</strong>的非官方应援站，由热爱她的粉丝们自发搭建。
            我们希望为所有喜欢东爱璃的观众提供一个温馨的线上空间，
            在这里你可以了解她的最新动态、观看直播提醒、欣赏她的各种造型。
          </p>
          <p>
            <strong>东爱璃Lovely</strong>，来自 PSPLive 的虚拟主播，昵称「狍子」。
          </p>
          <blockquote class="official-intro">
            「我是来自PSPLive的虚拟主播 可爱的 杂谈整活唱跳主持都会一点的～东北小狍子（不是偶像）的东爱璃Lovely！！！」
          </blockquote>
          <p>
            她总是元气满满，用可爱的形象和有趣的直播内容深受观众喜爱，感谢每一位粉丝的支持！
        </div>

        <div class="content-card">
          <h2>❤️ 为什么建这个站？</h2>
          <p>
            因为喜欢啊！作为东爱璃的粉丝，我们希望能够为她的粉丝社区贡献一份力量。
            这个站是我们表达支持的方式，也希望能够帮助更多人了解和喜欢上她。
          </p>
          <p>
            我们会持续更新这个站，添加更多有趣的功能和内容。
            如果你有任何建议或想法，欢迎联系我们！
          </p>
        </div>

        <div class="content-card">
          <h2>🛠️ 技术栈</h2>
          <ul class="tech-list">
            <li><strong>前端框架：</strong>Astro 5 + React 19</li>
            <li><strong>样式：</strong>Tailwind CSS + 自定义设计系统</li>
            <li><strong>部署：</strong>Cloudflare Pages</li>
            <li><strong>数据来源：</strong>Bilibili API</li>
          </ul>
          <p class="tech-note">
            本站是开源项目，欢迎有能力的粉丝一起参与建设！
          </p>
        </div>

        <div class="content-card highlight">
          <h2>✨ 功能特色</h2>
          <div class="features-grid">
            <div class="feature-item">
              <span class="feature-icon">📺</span>
              <h3>直播提醒</h3>
              <p>实时检测直播状态，第一时间知道开播</p>
            </div>
            <div class="feature-item">
              <span class="feature-icon">📸</span>
              <h3>造型展示</h3>
              <p>收录 32+ 种造型，欣赏狍子的各种样子</p>
            </div>
            <div class="feature-item">
              <span class="feature-icon">📊</span>
              <h3>数据统计</h3>
              <p>粉丝数等数据实时更新</p>
            </div>
            <div class="feature-item">
              <span class="feature-icon">📱</span>
              <h3>响应式设计</h3>
              <p>完美适配各种设备，随时随地访问</p>
            </div>
          </div>
        </div>

        <!-- 贡献者墙 -->
        <div class="content-card">
          <h2>💝 特别致谢</h2>
          <ContributorsWall client:load />
        </div>

        <div class="disclaimer">
          <div class="disclaimer-icon">⚠️</div>
          <div class="disclaimer-content">
            <h3>免责声明</h3>
            <p>
              本站为粉丝自发建设的非官方站点，与 <strong>东爱璃 Lovely</strong> 本人及 PSPLive 无直接关联。
              所有内容仅供参考，官方信息请以 Bilibili 主页为准。
            </p>
          </div>
        </div>



        <div class="links-section">
          <h3>🔗 相关链接</h3>
          <div class="links-grid">
            <a href="https://space.bilibili.com/3821157" target="_blank" rel="noopener" class="link-btn bilibili">
              <span>Bilibili 主页</span>
            </a>
            <a href="https://live.bilibili.com/21692711" target="_blank" rel="noopener" class="link-btn live">
              <span>直播间</span>
            </a>
            <a href="https://weibo.com/u/7802960328" target="_blank" rel="noopener" class="link-btn weibo">
              <span>微博</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="back-section">
      <a href="/" class="back-btn">← 返回首页</a>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .about-page {
    padding-top: 70px;
    min-height: 100vh;
    background: linear-gradient(180deg, #FFF8F0 0%, #F5EDE3 100%);
  }

  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .hero-section {
    padding: 60px 20px 40px;
    text-align: center;
    background: linear-gradient(135deg, rgba(157, 132, 183, 0.1) 0%, rgba(106, 76, 147, 0.1) 100%);
  }

  .page-title {
    font-size: 42px;
    color: #6B5637;
    margin: 0 0 10px 0;
  }

  .page-subtitle {
    font-size: 18px;
    color: #8B6F47;
    margin: 0;
  }

  .content-section {
    padding: 40px 20px;
  }

  .content-card {
    background: linear-gradient(135deg, rgba(255, 253, 250, 0.9) 0%, rgba(255, 248, 240, 0.95) 100%);
    backdrop-filter: blur(10px);
    border-radius: 20px;
    padding: 30px;
    margin-bottom: 24px;
    box-shadow: 0 4px 20px rgba(157, 132, 183, 0.12);
    border: 1px solid rgba(255, 248, 240, 0.6);
  }
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(10px);
    border-radius: 20px;
    padding: 30px;
    margin-bottom: 24px;
    box-shadow: 0 4px 20px rgba(157, 132, 183, 0.15);
    border: 1px solid rgba(157, 132, 183, 0.1);
  }

  .content-card h2 {
    font-size: 24px;
    color: #7B4B7C;
    margin: 0 0 20px 0;
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 600;
  }
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(10px);
    border-radius: 16px;
    padding: 30px;
    margin-bottom: 24px;
    box-shadow: 0 4px 20px rgba(139, 111, 71, 0.08);
  }

  .content-card h2 {
    font-size: 24px;
    color: #6B5637;
    margin: 0 0 16px 0;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .content-card p {
    font-size: 15px;
    color: #5C4A30;
    line-height: 1.8;
    margin: 0 0 12px 0;
  }

  .content-card p:last-child {
    margin-bottom: 0;
  }

  .official-intro {
    background: linear-gradient(135deg, rgba(157, 132, 183, 0.1) 0%, rgba(106, 76, 147, 0.1) 100%);
    border-left: 4px solid #9d84b7;
    padding: 16px 20px;
    margin: 16px 0;
    border-radius: 0 12px 12px 0;
    font-size: 15px;
    color: #5C4A30;
    font-style: italic;
    line-height: 1.8;
  }

  .content-card.highlight {
    background: linear-gradient(135deg, rgba(157, 132, 183, 0.08) 0%, rgba(106, 76, 147, 0.08) 100%);
    border: 1px solid rgba(157, 132, 183, 0.2);
  }

  .tech-list {
    list-style: none;
    padding: 0;
    margin: 0 0 16px 0;
  }

  .tech-list li {
    padding: 8px 0;
    border-bottom: 1px solid rgba(139, 111, 71, 0.1);
    font-size: 15px;
    color: #5C4A30;
  }

  .tech-list li:last-child {
    border-bottom: none;
  }

  .tech-note {
    font-size: 13px !important;
    color: #8B6F47 !important;
    font-style: italic;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-top: 20px;
  }

  .feature-item {
    text-align: center;
    padding: 20px;
    background: rgba(255, 255, 255, 0.6);
    border-radius: 12px;
  }

  .feature-icon {
    font-size: 32px;
    display: block;
    margin-bottom: 10px;
  }

  .feature-item h3 {
    font-size: 16px;
    color: #6B5637;
    margin: 0 0 8px 0;
  }

  .feature-item p {
    font-size: 13px !important;
    color: #8B6F47 !important;
    margin: 0 !important;
    line-height: 1.5 !important;
  }

  .thanks-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .thanks-list li {
    padding: 10px 0;
    font-size: 15px;
    color: #5C4A30;
    border-bottom: 1px solid rgba(139, 111, 71, 0.1);
  }

  .thanks-list li:last-child {
    border-bottom: none;
  }

  .disclaimer {
    background: linear-gradient(135deg, rgba(255, 200, 100, 0.12) 0%, rgba(255, 180, 50, 0.08) 100%);
    border: 1px solid rgba(255, 180, 50, 0.25);
    border-radius: 16px;
    padding: 24px 28px;
    margin-bottom: 24px;
    display: flex;
    gap: 20px;
    align-items: flex-start;
    box-shadow: 0 2px 12px rgba(255, 180, 50, 0.08);
  }

  .disclaimer-icon {
    font-size: 32px;
    flex-shrink: 0;
    line-height: 1;
  }

  .disclaimer-content {
    flex: 1;
  }

  .disclaimer-content h3 {
    font-size: 16px;
    font-weight: 600;
    color: #8B6F47;
    margin: 0 0 8px 0;
  }

  .disclaimer-content p {
    font-size: 13px;
    color: #6B5637;
    margin: 0;
    line-height: 1.8;
  }

  .disclaimer-content strong {
    font-weight: 600;
    color: #8B6F47;
  }


  .links-section {
    text-align: center;
    padding: 30px 0;
  }

  .links-section h3 {
    font-size: 20px;
    color: #6B5637;
    margin: 0 0 20px 0;
  }

  .links-grid {
    display: flex;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .link-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 500;
    font-size: 14px;
    transition: all 0.3s ease;
  }

  .link-btn.bilibili {
    background: linear-gradient(135deg, #FB7299 0%, #E85A7A 100%);
    color: white;
  }

  .link-btn.live {
    background: linear-gradient(135deg, #6a4c93 0%, #9d84b7 100%);
    color: white;
  }

  .link-btn.weibo {
    background: linear-gradient(135deg, #FF8200 0%, #E65C00 100%);
    color: white;
  }

  .link-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
  }

  .back-section {
    text-align: center;
    padding: 40px 20px 60px;
  }

  .back-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    background: linear-gradient(135deg, #9d84b7 0%, #6a4c93 100%);
    color: white;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 500;
    font-size: 15px;
    transition: all 0.3s ease;
  }

  .back-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(106, 76, 147, 0.3);
  }

  @media (max-width: 600px) {
    .page-title {
      font-size: 32px;
    }

    .features-grid {
      grid-template-columns: 1fr;
    }

    .content-card {
      padding: 24px;
    }

    .disclaimer {
      flex-direction: column;
      gap: 12px;
      padding: 20px;
    }

    .disclaimer-icon {
      font-size: 28px;
    }

    .disclaimer-content h3 {
      font-size: 15px;
    }

    .links-grid {
      flex-direction: column;
      align-items: center;
    }

    .link-btn {
      width: 200px;
      justify-content: center;
    }
  }
</style>